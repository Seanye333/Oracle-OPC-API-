# ============================================================
# Oracle OPC P6 Pipeline - Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Oracle Primavera Cloud (OPC) ---
OPC_TENANT=your-tenant-name
OPC_BASE_URL=https://your-tenant.oraclecloud.com/ppmrestapi/v2
OPC_TOKEN_URL=https://idcs-your-tenant.identity.oraclecloud.com/oauth2/v1/token
OPC_CLIENT_ID=your-opc-client-id
OPC_CLIENT_SECRET=your-opc-client-secret
OPC_SCOPE=https://your-tenant.oraclecloud.com/ppmrestapi/v2

# --- Oracle Database ---
ORACLE_HOST=your-oracle-host
ORACLE_PORT=1521
ORACLE_SERVICE=your-service-name
ORACLE_USER=p6_pipeline_user
ORACLE_PASSWORD=your-oracle-password
ORACLE_SCHEMA=P6_DATA

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_RAW_BUCKET=p6-raw
MINIO_PROCESSED_BUCKET=p6-processed

# --- Airflow ---
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-base64
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__WEBSERVER__SECRET_KEY=your-webserver-secret-key
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# --- Docker Registry (Jenkins) ---
DOCKER_REGISTRY=your-registry.example.com
DOCKER_IMAGE_NAME=oracle-opc-pipeline
DOCKER_IMAGE_TAG=latest
